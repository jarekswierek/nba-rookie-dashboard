# Required — no defaults
POSTGRES_PASSWORD=postgres

# Create key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith tracing — create account at https://smith.langchain.com
# → new project "nba-rookie-dashboard" → copy API key
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=nba-rookie-dashboard

# Optional — public URL of the UI service; used for CORS
# FRONTEND_URL=http://localhost:8501
